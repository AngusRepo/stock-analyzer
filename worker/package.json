{
  "name": "stockvision-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "db:init": "wrangler d1 execute stockvision-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute stockvision-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  }
}
