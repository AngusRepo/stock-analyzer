# .dockerignore — trim build context for repo-root Dockerfile (ml-controller Cloud Run Service)
# Only ml-controller/ and ml-service/ are needed in image; everything else
# bloats build upload.

# Git + IDE
.git/
.gitignore
.vscode/
.idea/
.github/
.claude/

# Node / worker
frontend/
worker/node_modules/
worker/dist/
worker/.wrangler/
worker/build/
worker/.tmp/

# Python caches
.uv-cache/
.uv-python/
.uv-tools/
.venv/
.venv-smoke/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Large dirs not needed in image
data/*
!data/finlab_research/
data/finlab_research/*
!data/finlab_research/dagster_asset_graph.json
!data/feature_registry/
data/feature_registry/*
!data/feature_registry/*.json
!output/
output/*
!output/feature_universe_triage/
output/feature_universe_triage/*
!output/feature_universe_triage/feature_registry_local_closure_20260617.json
!output/feature_universe_triage/formal137_pairwise_similarity_long_20260617.csv
ml-service/benchmark_results/
.tmp/
.wrangler/
_external/
freqtrade/
shioaji-proxy/
infra/
memory/
docs/
notebooks/
scripts/
!ml-service/scripts/
!ml-service/scripts/**
screen_*.png
/*.json
*.md
*.ipynb
*.log
*.tmp

# Test fixtures / local-only
**/tests/
**/tests/fixtures/
**/test_*.py
**/*_test.py

# Worker source needed by screener-v2 Cloud Run Job; keep generated/cache output out.
worker/
!worker/
worker/*
!worker/package.json
!worker/package-lock.json
!worker/tsconfig.json
!worker/tsconfig.tests.json
!worker/src/
!worker/src/**
worker/src/lib/canonicalTradeLifecycle.ts
!worker/migration_strategy_mining_ledger_2026_06_18.sql

# Scripts/tools root (not needed in ml-controller except the FinLab backfill helper copied by Dockerfile)
deploy_ml_controller.sh
tools/*
!tools/finlab_v4_remote_backfill.py
!tools/finlab_macro_context_snapshot.py
!tools/finlab_alpha_miner_bakeoff.py
!tools/finlab_alphabuilders_factor_backtest.py
!tools/finlab_strategy_spec_backtest.py
!tools/feature_strategy_overlap_numeric.py
*.sh
