{
  "schema_version": "stockvision-strategy-promotion-factor-gate-policy-v1",
  "decision_effect": "promotion_preflight_only",
  "policy": {
    "purpose": "Per-factor promotion gates for new active strategies. A strategy cannot be promoted if required factors cannot be resolved to runtime-normalized fields or exact materialization stats.",
    "active12_first": true,
    "broker_reclaim_retirement_rule": "Keep BrokerReclaim in Candidate12 first. Retire BrokerReclaim only after Candidate11-noBroker is tested against Candidate12 with the same fixed backtest contract.",
    "fixed_backtest_contract": {
      "start_date": "2023-01-01",
      "end_date": "2026-06-15",
      "universe": "sii",
      "resample": "M",
      "top_k": 10,
      "required_extra_slippage_bps": [0, 50, 100]
    }
  },
  "defaults_by_factor_type": {
    "price_technical": {
      "coverage_min": 0.95,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_lookback_only"
    },
    "technical": {
      "coverage_min": 0.95,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_lookback_only"
    },
    "volume": {
      "coverage_min": 0.95,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_lookback_only"
    },
    "l1_signal": {
      "coverage_min": 0.95,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_lookback_only"
    },
    "valuation": {
      "coverage_min": 0.85,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "reported_asof_no_future_leakage"
    },
    "fundamental_factor_diversity": {
      "coverage_min": 0.85,
      "min_unique_values": 20,
      "exact_stats_required": true,
      "asof_lag_rule": "reported_asof_no_future_leakage"
    },
    "chip_margin_flow": {
      "coverage_min": 0.75,
      "min_unique_values": 10,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_reported_delay"
    },
    "market_regime": {
      "coverage_min": 0.95,
      "min_unique_values": 10,
      "exact_stats_required": true,
      "asof_lag_rule": "same_day_or_lookback_only"
    },
    "runtime_gate": {
      "coverage_min": 1.0,
      "min_unique_values": 0,
      "exact_stats_required": false,
      "asof_lag_rule": "runtime_gate_not_factor"
    }
  },
