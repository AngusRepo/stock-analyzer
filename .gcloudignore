# Source upload ignore list for `gcloud run deploy --source .`.
# Keep Cloud Run CPD focused on the root Dockerfile plus ml-controller/ml-service
# source and the small FinLab runtime manifest copied by Dockerfile.

.git/
.gitignore
.gcloudignore
.vscode/
.idea/
.github/
.claude/

node_modules/
**/node_modules/
frontend/
worker/
!worker/
worker/*
!worker/migration_strategy_mining_ledger_2026_06_18.sql

.uv-cache/
.uv-python/
.uv-tools/
.venv/
.venv-smoke/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/tests/
**/test_*.py
**/*_test.py

.tmp/
worker/.tmp/
.wrangler/
_external/
freqtrade/
shioaji-proxy/
ml-service/benchmark_results/
infra/
scripts/
!ml-service/scripts/
!ml-service/scripts/**
screen_*.png
/*.json
data/*
!data/finlab_research/
data/finlab_research/*
!data/finlab_research/dagster_asset_graph.json
!data/feature_registry/
data/feature_registry/*
!data/feature_registry/*.json
!output/
output/*
!output/feature_universe_triage/
output/feature_universe_triage/*
!output/feature_universe_triage/feature_registry_local_closure_20260617.json

tools/*
!tools/finlab_v4_remote_backfill.py
!tools/finlab_macro_context_snapshot.py

deploy_ml_controller.sh
*.md
*.ipynb
*.log
*.tmp
osv-report*.json
osv-report*.html
