# ── StockVision Backfill 環境變數 ──────────────────────────────────────────
# 複製此檔案為 .env，填入你的實際值後執行 backfill.ts

# FinMind API Token（https://finmindtrade.com → 會員中心）
FINMIND_TOKEN=your_finmind_token_here

# ML 服務 URL（Cloud Run 部署完成後取得）
# 格式：https://stockvision-ml-xxxxxxxxxx-uc.a.run.app
ML_SERVICE_URL=https://your-cloud-run-url.run.app

# Cloudflare 帳號 ID（Dashboard 右側邊欄）
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# D1 資料庫 ID（Dashboard → Workers & Pages → D1 → stockvision-db → Database ID）
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id_here

# Cloudflare API Token（需要 D1:Edit 權限）
# 建立方式：Dashboard → My Profile → API Tokens → Create Token → 選 D1 Edit
CLOUDFLARE_API_TOKEN=your_api_token_here

# 回填起始日（可選，預設為 500 天前）
# BACKFILL_START_DATE=2023-01-01
