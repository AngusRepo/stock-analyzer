# .dockerignore — trim build context for repo-root Dockerfile (ml-controller Cloud Run Service)
# Only ml-controller/ and ml-service/ are needed in image; everything else
# bloats build upload.

# Git + IDE
.git/
.gitignore
.vscode/
.idea/
.github/
.claude/

# Node / worker
frontend/
worker/node_modules/
worker/dist/
worker/.wrangler/
worker/build/
worker/.tmp/

# Python caches
.uv-cache/
.uv-python/
.uv-tools/
.venv/
.venv-smoke/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Large dirs not needed in image
data/*
!data/finlab_research/
data/finlab_research/*
!data/finlab_research/dagster_asset_graph.json
.tmp/
.wrangler/
_external/
freqtrade/
shioaji-proxy/
infra/
memory/
docs/
notebooks/
scripts/
!ml-service/scripts/
!ml-service/scripts/**
screen_*.png
/*.json
*.md
*.ipynb
*.log
*.tmp

# Test fixtures / local-only
**/tests/
**/tests/fixtures/
**/test_*.py
**/*_test.py

# Worker-only (ml-controller image doesn't need CF code)
worker/

# Scripts/tools root (not needed in ml-controller except the FinLab backfill helper copied by Dockerfile)
deploy_ml_controller.sh
tools/*
!tools/finlab_v4_remote_backfill.py
!tools/finlab_macro_context_snapshot.py
*.sh
