# .dockerignore — trim build context for repo-root Dockerfile (ml-controller Cloud Run Service)
# Only ml-controller/ and ml-service/ are needed in image; everything else
# bloats build upload.

# Git + IDE
.git/
.gitignore
.vscode/
.idea/

# Node / worker
worker/node_modules/
worker/dist/
worker/.wrangler/
worker/build/

# Python caches
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Large dirs not needed in image
_external/
memory/
docs/
notebooks/
*.md
*.ipynb
*.log
*.tmp

# Test fixtures / local-only
**/tests/fixtures/
**/test_*.py
**/*_test.py

# Worker-only (ml-controller image doesn't need CF code)
worker/

# Scripts root (not needed in ml-controller)
deploy_ml_controller.sh
*.sh
