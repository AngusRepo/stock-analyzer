{
  "owner": "gcp-scheduler",
  "timeZone": "UTC",
  "workerBaseUrlEnv": "STOCKVISION_WORKER_BASE_URL",
  "authTokenEnv": "SCHEDULER_AUTH_TOKEN",
  "jobs": [
    { "id": "intraday-check", "schedule": "* 1-5 * * 1-5", "task": "intraday-check", "description": "TW 09:00-13:30 intraday paper trading heartbeat" },
    { "id": "rescore-10", "schedule": "0 2 * * 1-5", "task": "intraday-rescore", "query": "sync=1", "description": "TW 10:00 intraday ML re-score" },
    { "id": "rescore-11", "schedule": "0 3 * * 1-5", "task": "intraday-rescore", "query": "sync=1", "description": "TW 11:00 intraday ML re-score" },
    { "id": "rescore-12", "schedule": "0 4 * * 1-5", "task": "intraday-rescore", "query": "sync=1", "description": "TW 12:00 intraday ML re-score" },
    { "id": "rescore-1230", "schedule": "30 4 * * 1-5", "task": "intraday-rescore", "query": "sync=1", "description": "TW 12:30 intraday ML re-score" },
    { "id": "eod-exit", "schedule": "25 5 * * 1-5", "task": "eod-exit", "description": "TW 13:25 EOD exit" },
    { "id": "daily-snapshot", "schedule": "20 6 * * 1-5", "task": "daily-snapshot", "description": "TW 14:20 paper account snapshot" },
    { "id": "market-close-refresh", "schedule": "10 10 * * 1-5", "task": "market-close-refresh", "query": "sync=1", "description": "TW 18:10 early post-close refresh for official prices, market breadth, futures snapshot, and close-data cache" },
    { "id": "source-readiness-probe-1830-1850", "schedule": "30,50 10 * * 1-5", "task": "source-readiness-probe", "query": "sync=1", "description": "TW 18:30 and 18:50 readiness probe; triggers full evening chain when FinLab/official sources are current" },
    { "id": "source-readiness-probe-1910-2150", "schedule": "10,30,50 11-13 * * 1-5", "task": "source-readiness-probe", "query": "sync=1", "description": "TW 19:10-21:50 readiness probe every 20 minutes; triggers full evening chain when FinLab/official sources are current" },
    { "id": "evening-chain", "schedule": "0 14 * * 1-5", "task": "evening-chain", "query": "sync=1", "description": "TW 22:00 fallback root; suppressed when readiness probe already completed the full chain" },
    { "id": "weekly-audit", "schedule": "30 10 * * 5", "task": "weekly-audit", "description": "Friday TW 18:30 weekly audit" },
    { "id": "model-ic-tracker", "schedule": "30 11 * * 5", "task": "model-ic-tracker", "description": "Friday TW 19:30 model IC tracker" },
    { "id": "debate-memory-retention", "schedule": "0 19 * * *", "task": "debate-memory-retention", "description": "TW 03:00 debate memory retention" },
    { "id": "weekly-cleanup", "schedule": "0 20 * * 6", "task": "weekly-cleanup", "query": "sync=1", "description": "Sunday TW 04:00 lightweight cleanup + lifecycle check; no retrain" },
    { "id": "weekly-backtest", "schedule": "0 22 * * 6", "task": "weekly-backtest", "query": "sync=1", "description": "Sunday TW 06:00 lightweight validation: backtest, MC, PBO" },
    { "id": "alpha-quality", "schedule": "0 22 * * 6", "task": "alpha-quality", "query": "sync=1", "description": "Sunday TW 06:00 alpha quality refresh" },
    { "id": "weekly-optuna", "schedule": "30 22 * * 6", "task": "weekly-optuna", "query": "sync=1", "description": "Sunday TW 06:30 lightweight Optuna/GA calibration" },
    { "id": "adaptive-meta-policy-replay", "schedule": "40 22 * * 6", "task": "adaptive-meta-policy-replay", "query": "sync=1&persist=1", "headers": { "X-Confirm-Meta-Learning": "true" }, "description": "Sunday TW 06:40 persisted evidence-only active-9 replay comparing LinUCB, NeuralUCB, NeuralTS, and NeuCB" },
    { "id": "linucb-multiplier-replay", "schedule": "50 22 * * 6", "task": "linucb-multiplier-replay", "query": "sync=1&persist=1", "headers": { "X-Confirm-Meta-Learning": "true" }, "description": "Sunday TW 06:50 persisted evidence-only active-9 replay for LinUCB bandit_* multiplier constants" },
    { "id": "sector-leaders", "schedule": "30 22 * * 6", "task": "sector-leaders", "query": "sync=1", "description": "Sunday TW 06:30 sector leader correlation refresh" },
    { "id": "monthly-optuna", "schedule": "first saturday of month 16:00", "timeZone": "Asia/Taipei", "task": "monthly-optuna", "query": "sync=1", "description": "Monthly first Saturday TW 16:00 Optuna research sweep" },
    { "id": "monthly-strategy-mining", "schedule": "first saturday of month 10:00", "timeZone": "Asia/Taipei", "task": "monthly-strategy-mining", "query": "sync=1&persist=1", "description": "Monthly first Saturday TW 10:00 pymoo NSGA-III + novelty strategy mining preflight/research ledger" },
    { "id": "monthly-retrain", "schedule": "first sunday of month 02:00", "timeZone": "Asia/Taipei", "task": "monthly-retrain", "query": "sync=1", "description": "Monthly first Sunday TW 02:00 universal retrain lifecycle" },
    { "id": "optuna-queue", "schedule": "0 */6 * * *", "task": "optuna-queue", "query": "sync=1", "description": "Every six hours Optuna queue processor" },
    { "id": "us-leading", "schedule": "30 22 * * 0-4", "task": "us-leading", "description": "TW 06:30 US leading signal" },
    { "id": "news-analyst", "schedule": "45 22 * * 0-4", "task": "news-analyst", "description": "TW 06:45 news analyst" },
    { "id": "morning-setup", "schedule": "15 23 * * 0-4", "task": "morning-setup", "description": "TW 07:15 morning setup and debate" },
    { "id": "morning-briefing", "schedule": "50 23 * * 0-4", "task": "morning-briefing", "description": "TW 07:50 morning briefing" },
    { "id": "pre-market-warmup", "schedule": "50 0 * * 1-5", "task": "pre-market-warmup", "description": "TW 08:50 control-plane drift and debate reconciliation" }
  ]
}
