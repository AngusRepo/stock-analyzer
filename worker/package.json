{
  "name": "stockvision-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tests.json",
    "db:init": "wrangler d1 execute stockvision-db --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute stockvision-db --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "4.12.25"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "6.0.3",
    "wrangler": "4.100.0"
  }
}
